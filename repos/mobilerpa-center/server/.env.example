# MobileRPA Center 本地默认配置模板
#
# 使用方式：
# 1. 复制本文件为 .env
# 2. 按本机实际情况调整配置值
# 3. 在 server 目录执行：go run .\cmd\center
#
# 优先级：
# 1. 进程环境变量
# 2. .env 文件
# 3. 程序内置默认值

CENTER_HTTP_ADDR=0.0.0.0:28080
CENTER_DB_PATH=./data/mobilerpa.db

# 跨域白名单，开发环境默认允许 Vite 本地地址
CENTER_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 心跳与离线判定
CENTER_HEARTBEAT_INTERVAL=30s
CENTER_DEVICE_OFFLINE_TIMEOUT=90s
CENTER_DEVICE_OFFLINE_SCAN_INTERVAL=15s

# ADB 与 Agent 下发配置
CENTER_ADB_PATH=adb
CENTER_AGENT_ROOT_PATH=../../mobilerpa-agent/agent

# 可选：独立 Go 工具路径。
# 中心服务网页下发 Agent 时将直接调用该工具。
# 示例：
# CENTER_TOOLKIT_PATH=D:\dev\code\mobilerpa\.tmp\mobilerpa-toolkit.exe
CENTER_TOOLKIT_PATH=

# 会写入真机 bootstrap 配置，必须填写“手机能够访问到”的中心服务地址。
CENTER_BASE_URL=http://127.0.0.1:28080

# 中心服务日志。
# 会按天写入 ./data/logs/server 下的 app/ws/scheduler/error 日志，并保留最近 7 天。
CENTER_LOG_ROOT_PATH=./data/logs
CENTER_LOG_RETENTION_DAYS=7

# 文档访问控制。
# 为 true 时，访问 /scalar 和 /openapi.json 需要输入用户名密码。
CENTER_DOCS_AUTH_ENABLED=true
CENTER_DOCS_AUTH_USERNAME=admin
CENTER_DOCS_AUTH_PASSWORD=123456
