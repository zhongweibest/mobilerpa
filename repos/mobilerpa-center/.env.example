# MobileRPA Center 本地默认配置模板
#
# 使用方式：
# 1. 复制本文件为 .env
# 2. 按本机实际情况调整配置值
# 3. 进入 server 目录后执行：go run .\cmd\center
#
# 优先级：
# 1. 进程环境变量优先级最高，例如 PowerShell 中手工设置的 $env:CENTER_HTTP_ADDR
# 2. .env 文件中的配置
# 3. 程序内置默认值

CENTER_HTTP_ADDR=0.0.0.0:18080
CENTER_DB_PATH=D:\dev\code\mobilerpa\.tmp\mobilerpa-center-manual.db
CENTER_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CENTER_HEARTBEAT_INTERVAL=30s
CENTER_DEVICE_OFFLINE_TIMEOUT=90s
CENTER_DEVICE_OFFLINE_SCAN_INTERVAL=15s
CENTER_PLAN_SCAN_INTERVAL=1s
CENTER_PLAN_START_WORKERS=2
CENTER_PLAN_START_FANOUT=20

# 设备发现与网页批量下发 Agent 相关配置
# CENTER_ADB_PATH 支持写 adb，或写成 adb.exe 的绝对路径
CENTER_ADB_PATH=adb

# CENTER_PUSH_AGENT_SCRIPT_PATH 默认指向中心服务使用的非交互批处理脚本
CENTER_PUSH_AGENT_SCRIPT_PATH=../../mobilerpa-agent/tools/adb-debug/push-agent-center.bat

# CENTER_BASE_URL 会写入手机端 bootstrap 配置，供 Agent 首次启动时连接中心服务
CENTER_BASE_URL=http://127.0.0.1:18080
